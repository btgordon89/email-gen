# Copy this file to .env and fill in your values

# ── Required ────────────────────────────────────────────────────────────

# Google Gemini (text + image generation)
GOOGLE_API_KEY=your_google_api_key_here

# Shopify Admin API (product data, inventory, pricing)
SHOPIFY_SHOP_URL=your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=your_shopify_admin_api_token_here

# Klaviyo (image CDN upload + email template management)
KLAVIYO_API_KEY=your_klaviyo_api_key_here

# ── Optional ────────────────────────────────────────────────────────────

# Anthropic Claude (alternative copy generation — leave blank to use Gemini only)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Brand identity (used in email assembly)
# BRAND_STOREFRONT_URL=https://yourstore.com
# BRAND_LOGO_URL=https://cdn.example.com/your-logo.png

# Brand social links (used in email footers)
# BRAND_INSTAGRAM_URL=https://www.instagram.com/yourbrand
# BRAND_TIKTOK_URL=https://www.tiktok.com/@yourbrand
# BRAND_FACEBOOK_URL=https://www.facebook.com/yourbrand

# ── Model overrides ─────────────────────────────────────────────────────
# Per-step model selection. Defaults shown — comment out to use defaults.
# Priority: env var > models_config.yaml > built-in default

# EMAIL_TEXT_MODEL=gemini-2.5-flash       # generic helper default
# EMAIL_BRIEF_MODEL=gemini-2.5-pro
# EMAIL_STRUCTURE_MODEL=gemini-2.5-flash
# EMAIL_DISCOUNT_MODEL=gemini-2.5-flash
# EMAIL_PRODUCTS_MODEL=gemini-2.5-flash
# EMAIL_COPY_MODEL=gemini-2.5-pro
# EMAIL_LINKS_MODEL=gemini-2.5-flash
# EMAIL_COHESION_MODEL=gemini-2.5-pro
# EMAIL_IMAGE_MODEL=gemini-3-pro-image-preview
# EMAIL_ASSEMBLY_MODEL=gemini-2.5-pro
# EMAIL_REVIEW_MODEL=gemini-2.5-pro
# EMAIL_PATCH_MODEL=gemini-2.5-pro
